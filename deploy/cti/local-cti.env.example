# Local CTI runtime env.
# Generated copy target: runtime/cti/local.env

# CRM-side outbound config. Local dev forces env config so database settings do
# not accidentally keep CTI disabled.
OUTBOUND_CALL_FORCE_ENV_CONFIG=1
OUTBOUND_CALL_ENABLED=1
OUTBOUND_CALL_PROVIDER=FREESWITCH
OUTBOUND_CALL_GATEWAY_BASE_URL=http://127.0.0.1:8790
OUTBOUND_CALL_START_PATH=/calls/start
OUTBOUND_CALL_WEBHOOK_BASE_URL=http://127.0.0.1:3000/api/outbound-calls/webhooks/freeswitch
OUTBOUND_CALL_WEBHOOK_SECRET=__LOCAL_CTI_SECRET__
OUTBOUND_CALL_DEFAULT_ROUTING_GROUP=lbn-provider
OUTBOUND_CALL_DIAL_PREFIX=
OUTBOUND_CALL_DEFAULT_DISPLAY_NUMBER=
OUTBOUND_CALL_CODEC=PCMA
OUTBOUND_CALL_RECORD_ON_SERVER=1
OUTBOUND_CALL_RECORDING_IMPORT_MODE=WEBHOOK_URL
OUTBOUND_CALL_TIMEOUT_SECONDS=30
OUTBOUND_CALL_REQUIRE_WEBHOOK_SECRET=1
OUTBOUND_CALL_WEBHOOK_TOLERANCE_SECONDS=300

# Local CTI Gateway. Keep MOCK until a PBX is ready.
CTI_GATEWAY_MODE=MOCK
CTI_GATEWAY_HOST=127.0.0.1
CTI_GATEWAY_PORT=8790
CTI_GATEWAY_API_TOKEN=__LOCAL_CTI_SECRET__
CTI_GATEWAY_ALLOW_NO_AUTH=0
CTI_GATEWAY_DEFAULT_ROUTING_GROUP=lbn-provider
CTI_GATEWAY_REQUEST_TIMEOUT_MS=10000

# FreeSWITCH ESL control channel. Fill these after FreeSWITCH is installed.
CTI_GATEWAY_FREESWITCH_HOST=127.0.0.1
CTI_GATEWAY_FREESWITCH_PORT=8021
CTI_GATEWAY_FREESWITCH_PASSWORD=
CTI_GATEWAY_FREESWITCH_AGENT_ENDPOINT_TEMPLATE=user/{seatNo}
CTI_GATEWAY_FREESWITCH_CUSTOMER_ENDPOINT_TEMPLATE=sofia/gateway/{routingGroup}/{dialedNumber}

# Asterisk AMI control channel. Ubuntu/WSL local PBX can use this mode.
CTI_GATEWAY_ASTERISK_HOST=127.0.0.1
CTI_GATEWAY_ASTERISK_PORT=5038
CTI_GATEWAY_ASTERISK_USERNAME=lbn_cti_gateway
CTI_GATEWAY_ASTERISK_PASSWORD=__LOCAL_CTI_SECRET__
CTI_GATEWAY_ASTERISK_AGENT_ENDPOINT_TEMPLATE=PJSIP/{seatNo}
CTI_GATEWAY_ASTERISK_CONTEXT=crm-outbound
CTI_GATEWAY_ASTERISK_CUSTOMER_EXTEN_TEMPLATE={dialedNumber}
CTI_ASTERISK_TRUNK_QUALIFY_FREQUENCY=0
CTI_ASTERISK_RECORDING_DIR=/var/spool/asterisk/monitor/lbn-crm
CTI_ASTERISK_POST_CALL_WEBHOOK_SCRIPT=/usr/local/bin/lbn-crm-post-call-webhook.sh
CTI_POST_CALL_WEBHOOK_URL=http://127.0.0.1:3000/api/outbound-calls/webhooks/freeswitch
CTI_POST_CALL_WEBHOOK_LOG_FILE=/var/log/asterisk/lbn-crm-post-call-webhook.log
CTI_ASTERISK_DEFAULT_SEAT_NO=6001
CTI_ASTERISK_SEAT_NOS=6001
CTI_ASTERISK_DEFAULT_SEAT_PASSWORD=__LOCAL_CTI_SECRET__

# Browser WebRTC seat. Production must use HTTPS/WSS. Local localhost can use
# ws:// for smoke tests; LAN IP such as http://192.168.x.x needs HTTPS for mic.
OUTBOUND_CALL_WEBRTC_ENABLED=0
OUTBOUND_CALL_WEBRTC_PUBLIC_HOST=127.0.0.1
OUTBOUND_CALL_WEBRTC_SIP_DOMAIN=127.0.0.1
OUTBOUND_CALL_WEBRTC_WS_URL=ws://127.0.0.1:8088/ws
OUTBOUND_CALL_WEBRTC_DEFAULT_SEAT_PASSWORD=__LOCAL_CTI_SECRET__
OUTBOUND_CALL_WEBRTC_REGISTER_EXPIRES_SECONDS=300
OUTBOUND_CALL_WEBRTC_PREFERRED_CODECS=opus,pcma
OUTBOUND_CALL_WEBRTC_ICE_SERVERS_JSON=[]
CTI_ASTERISK_WEBRTC_ENABLED=0
CTI_ASTERISK_WEBRTC_TRANSPORT_NAME=lbn-crm-ws
CTI_ASTERISK_WEBRTC_TRANSPORT_PROTOCOL=ws
CTI_ASTERISK_WEBRTC_TRANSPORT_BIND=0.0.0.0
CTI_ASTERISK_WEBRTC_CODECS=opus,alaw,ulaw
CTI_ASTERISK_HTTP_ENABLED=yes
CTI_ASTERISK_HTTP_BIND_ADDR=0.0.0.0
CTI_ASTERISK_HTTP_BIND_PORT=8088
CTI_ASTERISK_HTTP_TLS_ENABLED=no
CTI_ASTERISK_HTTP_TLS_BIND_ADDR=0.0.0.0:8089
CTI_ASTERISK_HTTP_TLS_CERT_FILE=
CTI_ASTERISK_HTTP_TLS_PRIVATE_KEY=

# SIP provider account. These render a FreeSWITCH gateway XML file; CRM never
# reads the password directly.
CTI_SIP_GATEWAY_NAME=lbn-provider
CTI_SIP_USERNAME=
CTI_SIP_PASSWORD=
CTI_SIP_HOST=116.131.177.253
CTI_SIP_PORT=5060
CTI_SIP_REGISTER=true
CTI_SIP_CODEC=PCMA

# CRM recording storage must point to the same mounted directory as Asterisk
# recording output, or to an identical shared mount path.
CALL_RECORDING_STORAGE_PROVIDER=LOCAL_MOUNT
CALL_RECORDING_STORAGE_DIR=/var/spool/asterisk/monitor/lbn-crm
CALL_RECORDING_UPLOAD_TMP_DIR=/var/spool/asterisk/monitor/lbn-crm/.uploads
