enum OperationTargetType {
  USER
  TEAM
  ROLE
  LEAD
  LEAD_IMPORT_BATCH
  LEAD_IMPORT_ROW
  LEAD_IMPORT_TEMPLATE
  LEAD_DEDUP_LOG
  LEAD_CUSTOMER_MERGE_LOG
  CUSTOMER
  LEAD_ASSIGNMENT
  FOLLOW_UP_TASK
  CALL_RECORD
  WECHAT_RECORD
  LIVE_SESSION
  LIVE_INVITATION
  ORDER
  GIFT_RECORD
  SHIPPING_TASK
  SUPPLIER
  PRODUCT
  PRODUCT_SKU
  SALES_ORDER
