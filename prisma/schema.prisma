  CUSTOMER
  ASSIGNMENT
  FOLLOW_UP
  CALL
  WECHAT
  LIVE_SESSION
  ORDER
  GIFT
  SHIPPING
  SUPPLIER
  PRODUCT
  SALES_ORDER
  SHIPPING_EXPORT
